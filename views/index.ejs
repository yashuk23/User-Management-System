<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create User</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <style>
        @media (max-width:480px) {
            h1 {
                font-size: 20px;
            }

            h2 {
                font-size: 24px;
            }

            button {
                padding: 10px;
                font-size: 14px;
            }

            input {
                padding: 10px;
            }
        }
    </style>

</head>

<body class="bg-gradient-to-br from-indigo-200 via-purple-200 to-pink-200 min-h-screen flex flex-col">

    <nav
        class="w-full bg-white/70 backdrop-blur-md border-b border-white/40 px-4 sm:px-6 lg:px-10 py-4 flex flex-col sm:flex-row justify-between items-center gap-3 shadow-md">

        <h1 class="text-xl sm:text-2xl font-bold text-indigo-700 tracking-wide">
            User Management
        </h1>

        <div class="flex flex-wrap justify-center gap-3">

            <a href="/read"
                class="px-4 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg text-sm font-medium transition shadow-md">
                View Users
            </a>

            <a href="/logout"
                class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-medium transition shadow-md">
                Logout
            </a>

        </div>

    </nav>

    <div class="flex flex-1 justify-center items-center px-4 sm:px-6 py-8 sm:py-12">

        <div
            class="w-full max-w-md sm:max-w-lg bg-white/60 backdrop-blur-lg border border-white/40 rounded-2xl p-6 sm:p-8 md:p-10 shadow-2xl">

            <h2 class="text-2xl sm:text-3xl font-bold mb-6 sm:mb-8 text-center text-gray-800">
                Create New User
            </h2>

            <form action="/create" method="POST" class="space-y-5 sm:space-y-6">

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Name</label>
                    <input type="text" name="name" placeholder="Enter full name"
                        class="w-full px-4 py-3 text-sm sm:text-base rounded-lg bg-gray-100 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                    <input type="email" name="email" placeholder="Enter email"
                        class="w-full px-4 py-3 text-sm sm:text-base rounded-lg bg-gray-100 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Image URL</label>
                    <input type="text" name="image" value="https://cdn-icons-png.flaticon.com/512/149/149071.png"
                        placeholder="Paste image URL"
                        class="w-full px-4 py-3 text-sm sm:text-base rounded-lg bg-gray-100 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
                </div>

                <button type="submit"
                    class="w-full py-3 text-sm sm:text-base bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white rounded-lg font-semibold transition shadow-lg">
                    Create User
                </button>

            </form>

        </div>

    </div>

</body>

</html>