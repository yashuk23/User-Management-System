<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-blue-200 via-purple-200 to-pink-200 flex items-center justify-center min-h-screen">

    <div class="bg-purple-100/70 backdrop-blur-lg p-8 rounded-2xl shadow-xl w-96 border border-purple-300">

        <h1 class="text-3xl font-bold text-gray-800 text-center mb-6">
            Register
        </h1>

        <form action="/register" method="POST" class="space-y-4">

            <input type="text" name="name" placeholder="Name"
                class="w-full p-3 rounded-lg bg-purple-50 border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-400">

            <input type="email" name="email" placeholder="Email"
                class="w-full p-3 rounded-lg bg-purple-50 border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-400">

            <input type="password" name="password" placeholder="Password"
                class="w-full p-3 rounded-lg bg-purple-50 border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-400">

            <input type="text" name="image" placeholder="Image URL"
                class="w-full p-3 rounded-lg bg-purple-50 border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-400">

            <button type="submit"
                class="w-full bg-gradient-to-r from-purple-500 to-pink-500 text-white p-3 rounded-lg">
                Register
            </button>

            <a href="/login"
                class="block text-center text-purple-700 font-semibold hover:text-purple-900">
                Already have an account? Login
            </a>

        </form>
    </div>

</body>

</html>