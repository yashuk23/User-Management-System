<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body
    class="bg-gradient-to-br from-indigo-200 via-purple-200 to-pink-200 flex items-center justify-center min-h-screen">

    <div class="bg-white/70 backdrop-blur-xl p-10 rounded-2xl shadow-2xl w-96 border border-white/40">

        <h1 class="text-3xl font-bold text-gray-800 text-center mb-8">
            Login
        </h1>

        <form action="/login" method="POST" class="space-y-6">

            <div>
                <input type="email" name="email" placeholder="Email"
                    class="w-full p-3 rounded-lg bg-gray-100 text-gray-700 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
            </div>

            <div>
                <input type="password" name="password" placeholder="Password"
                    class="w-full p-3 rounded-lg bg-gray-100 text-gray-700 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
            </div>

            <button type="submit"
                class="w-full bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-semibold p-3 rounded-lg transition duration-300 shadow-lg">
                Login
            </button>

            <a href="/register"
                class="block text-center text-indigo-700 font-semibold hover:text-indigo-900 transition">
                Don't have an account? Register
            </a>

        </form>

    </div>


</body>

</html>