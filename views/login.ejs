<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-blue-200 via-purple-200 to-pink-200 flex items-center justify-center min-h-screen">

    <div class="bg-purple-100/70 backdrop-blur-lg p-8 rounded-2xl shadow-xl w-96 border border-purple-300">

        <h1 class="text-3xl font-bold text-gray-800 text-center mb-6">
            Login
        </h1>

        <form action="/login" method="POST" class="space-y-4">

            <input type="email" name="email" placeholder="Email"
                class="w-full p-3 rounded-lg bg-purple-50 text-gray-700 border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-400">

            <input type="password" name="password" placeholder="Password"
                class="w-full p-3 rounded-lg bg-purple-50 text-gray-700 border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-400">

            <button type="submit"
                class="w-full bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-semibold p-3 rounded-lg transition duration-300 shadow-lg cursor-pointer">
                Login
            </button>

            <a href="/register"
                class="block text-center text-purple-700 font-semibold hover:text-purple-900 transition cursor-pointer">
                Don't have an account? Register
            </a>

        </form>
    </div>

</body>

</html>