<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-slate-300 via-indigo-300 to-violet-300 flex items-center justify-center min-h-screen">

    <div class="bg-white/70 backdrop-blur-lg p-8 rounded-2xl shadow-xl w-96 border border-white/40">

        <h1 class="text-3xl font-bold text-gray-800 text-center mb-6">
            Login
        </h1>

        <form action="/login" method="POST" class="space-y-4">

            <input type="email" name="email" placeholder="Email"
                class="w-full p-3 rounded-lg bg-gray-100 text-gray-700 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-400">

            <input type="password" name="password" placeholder="Password"
                class="w-full p-3 rounded-lg bg-gray-100 text-gray-700 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-400">

            <button type="submit"
                class="w-full bg-gradient-to-r from-indigo-500 to-violet-500 hover:from-indigo-600 hover:to-violet-600 text-white font-semibold p-3 rounded-lg transition duration-300 shadow-lg cursor-pointer">
                Login
            </button>

            <a href="/register"
                class="block text-center text-indigo-700 font-semibold hover:text-indigo-900 transition cursor-pointer">
                Don't have an account? Register
            </a>

        </form>
    </div>

</body>

</html>