<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950 text-gray-200 min-h-screen flex flex-col">

    <nav class="w-full bg-gray-900/80 backdrop-blur-md border-b border-gray-800 px-8 py-4 flex justify-between items-center shadow-lg">
        <h1 class="text-xl font-semibold tracking-wide text-white">
            User Management System
        </h1>

        <a href="/"
           class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 hover:scale-105 active:scale-95 rounded-lg text-sm font-medium transition duration-200 shadow-md">
            Back to Home
        </a>
    </nav>

    <div class="max-w-6xl mx-auto px-6 py-12 w-full">

        <% if (users.length > 0) { %>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

                <% users.forEach(function(user){ %>

                    <div class="bg-gray-900/70 backdrop-blur-lg border border-gray-800 rounded-2xl p-7 shadow-xl hover:shadow-indigo-500/10 hover:-translate-y-1 transition duration-300 flex flex-col items-center text-center">

                        <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-gray-700 mb-5 shadow-md">
                            <img src="<%= user.image %>" alt="User Image" class="w-full h-full object-cover">
                        </div>

                        <h3 class="text-lg font-semibold text-white tracking-wide">
                            <%= user.name %>
                        </h3>

                        <h5 class="text-sm text-gray-400 mb-5">
                            <%= user.email %>
                        </h5>

                        <div class="flex gap-3">

                            <a href="/edit/<%= user._id %>"
                               class="px-4 py-1.5 bg-indigo-600 hover:bg-indigo-500 hover:scale-105 rounded-md text-sm font-medium transition duration-200 shadow">
                                Edit
                            </a>

                            <a href="/delete/<%= user._id %>"
                               class="px-4 py-1.5 bg-gray-800 hover:bg-gray-700 border border-gray-700 hover:scale-105 rounded-md text-sm font-medium transition duration-200">
                                Delete
                            </a>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } else { %>

            <div class="flex items-center justify-center h-64">
                <h1 class="text-2xl text-gray-400">No Users Yet</h1>
            </div>

        <% } %>

    </div>

</body>
</html>