<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-slate-300 via-indigo-300 to-violet-300 min-h-screen flex flex-col">

    <nav
        class="w-full bg-white/60 backdrop-blur-md border-b border-white/40 px-8 py-4 flex justify-between items-center shadow-md">

        <h1 class="text-xl font-semibold text-gray-800">
            User Management System
        </h1>

        <a href="/index"
            class="px-5 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg text-sm font-medium transition shadow">
            Back to Home
        </a>

    </nav>

    <div class="max-w-6xl mx-auto px-6 py-12 w-full">

        <% if (users.length > 0) { %>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

                <% users.forEach(function(user){ %>

                    <div
                        class="bg-white/70 backdrop-blur-lg border border-white/40 rounded-2xl p-7 shadow-lg flex flex-col items-center text-center">

                        <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-gray-300 mb-5">
                            <img src="<%= user.image %>" class="w-full h-full object-cover">
                        </div>

                        <h3 class="text-lg font-semibold text-gray-800">
                            <%= user.name %>
                        </h3>

                        <h5 class="text-sm text-gray-600 mb-5">
                            <%= user.email %>
                        </h5>

                        <div class="flex gap-3">

                            <a href="/edit/<%= user._id %>"
                                class="px-4 py-1.5 bg-indigo-500 hover:bg-indigo-600 text-white rounded-md text-sm font-medium transition">
                                Edit
                            </a>

                            <a href="/delete/<%= user._id %>"
                                class="px-4 py-1.5 bg-gray-200 hover:bg-gray-300 text-gray-700 border border-gray-300 rounded-md text-sm font-medium transition">
                                Delete
                            </a>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <% } else { %>

                <div class="flex items-center justify-center h-64">
                    <h1 class="text-2xl text-gray-600">No Users Yet</h1>
                </div>

                <% } %>

    </div>

</body>

</html>