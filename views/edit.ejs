<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-zinc-950 via-zinc-900 to-zinc-950 text-gray-200 min-h-screen flex flex-col">

    <nav class="w-full bg-zinc-900 border-b border-zinc-800 px-8 py-4 flex justify-between items-center shadow-lg">
        <h1 class="text-xl font-semibold text-gray-100">
            User Management System
        </h1>

        <a href="/read"
            class="px-5 py-2 bg-amber-500 hover:bg-amber-400 rounded-lg text-sm font-medium transition shadow-md">
            View Users
        </a>
    </nav>

    <div class="flex flex-1 justify-center px-4 py-12">

        <div class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-2xl p-10 shadow-xl">

            <h2 class="text-3xl font-semibold mb-8 text-center text-gray-100">
                Edit User
            </h2>

            <form action="/edit/<%= editid._id %>" method="POST" class="space-y-6">

                <div>
                    <label class="block text-sm text-gray-400 mb-2">Name</label>
                    <input type="text" name="name" value="<%= editid.name %>"
                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-amber-500">
                </div>

                <div>
                    <label class="block text-sm text-gray-400 mb-2">Email</label>
                    <input type="text" name="email" value="<%= editid.email %>"
                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-amber-500">
                </div>

                <div>
                    <label class="block text-sm text-gray-400 mb-2">Image URL</label>
                    <input type="text" name="image" value="<%= editid.image %>"
                        class="w-full px-4 py-3 rounded-lg bg-zinc-800 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-amber-500">
                </div>

                <button type="submit"
                    class="w-full py-3 bg-amber-500 hover:bg-amber-400 rounded-lg font-medium transition shadow-lg">
                    Update User
                </button>

            </form>

        </div>
    </div>

</body>

</html>