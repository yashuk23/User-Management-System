<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950 text-gray-200 min-h-screen flex flex-col">

    <nav class="w-full bg-gray-900/80 backdrop-blur-md border-b border-gray-800 px-8 py-4 flex justify-between items-center shadow-lg">
        <h1 class="text-xl font-semibold tracking-wide text-white">
            User Management System
        </h1>

        <a href="/read"
           class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 hover:scale-105 active:scale-95 rounded-lg text-sm font-medium transition duration-200 shadow-md">
            View Users
        </a>
    </nav>

    <div class="flex flex-1 justify-center px-4 py-12">

        <div class="w-full max-w-md bg-gray-900/70 backdrop-blur-lg border border-gray-800 rounded-2xl p-10 shadow-2xl hover:shadow-indigo-500/10 transition duration-300">

            <h2 class="text-3xl font-semibold mb-8 text-center text-white tracking-wide">
                Edit User
            </h2>

            <form action="/edit/<%= editid._id %>" method="POST" class="space-y-6">

                <div>
                    <label class="block text-sm text-gray-400 mb-2">Name</label>
                    <input 
                        type="text"
                        name="name"
                        value="<%= editid.name %>"
                        class="w-full px-4 py-3 rounded-lg bg-gray-800/80 border border-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200"
                    >
                </div>

                <div>
                    <label class="block text-sm text-gray-400 mb-2">Email</label>
                    <input 
                        type="text"
                        name="email"
                        value="<%= editid.email %>"
                        class="w-full px-4 py-3 rounded-lg bg-gray-800/80 border border-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200"
                    >
                </div>

                <div>
                    <label class="block text-sm text-gray-400 mb-2">Image URL</label>
                    <input 
                        type="text"
                        name="image"
                        value="<%= editid.image %>"
                        class="w-full px-4 py-3 rounded-lg bg-gray-800/80 border border-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200"
                    >
                </div>

                <button
                    type="submit"
                    class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 hover:scale-[1.02] active:scale-[0.98] rounded-lg font-medium transition duration-200 shadow-lg shadow-indigo-600/20"
                >
                    Update User
                </button>

            </form>

        </div>

    </div>

</body>
</html>